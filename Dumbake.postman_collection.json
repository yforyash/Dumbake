{
  "info": {
    "_postman_id": "c8d8b1f4-3d90-482a-a92c-806d2c499e90",
    "name": "Dumbake Bakery API",
    "description": "Comprehensive API collection for testing and developing Dumbake Full-stack platform endpoints including user authentication, OTP validation, inventory catalog, order checkouts, dashboard analytics, reviews, and AI recommendations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "User Authentication & OTP",
      "item": [
        {
          "name": "1. Generate & Send OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/send-otp",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "send-otp"
              ]
            },
            "description": "Generates a 6-digit random OTP verification code, saves it to the database for the given email (creating a stub unverified user if new), and sends a real email using SMTP."
          },
          "response": []
        },
        {
          "name": "2. Register Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"customer@example.com\",\n  \"passwordHash\": \"8d969eef6ecad3c29a3a629280e686cf0c3f5d5a86aff3ca12020c923adc6c92\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Registers a new user profile as unverified. Automatically assigns role = 'admin' if the email matches the configured ADMIN_EMAIL, otherwise registers as 'user'. Dispatches verification OTP code to email."
          },
          "response": []
        },
        {
          "name": "3. Verify OTP Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/verify",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "verify"
              ]
            },
            "description": "Validates the 6-digit OTP code sent to the email. If correct, sets is_verified = TRUE in the database and returns the logged-in user profile."
          },
          "response": []
        },
        {
          "name": "4. Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"passwordHash\": \"8d969eef6ecad3c29a3a629280e686cf0c3f5d5a86aff3ca12020c923adc6c92\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Authenticates user credentials. If the email is registered but unverified, returns a status of unverified and dispatches a fresh verification OTP code."
          },
          "response": []
        },
        {
          "name": "5. Fetch Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "1"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/profile",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "profile"
              ]
            },
            "description": "Retrieves the user session profile details using the x-user-id header."
          },
          "response": []
        },
        {
          "name": "6. Newsletter Subscription",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"gourmet@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/subscribe",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "subscribe"
              ]
            },
            "description": "Subscribes the email to the newsletter and sends a confirmation welcome email with a coupon code via SMTP."
          },
          "response": []
        }
      ]
    },
