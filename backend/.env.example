PORT=5001
NODE_ENV=development

# Cloud Database URL (Supabase/Neon connection string)
# Example: postgres://postgres.xxxx:yourpassword@aws-0-xxxx.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=

# Local Database Configuration (pgAdmin 4 / PostgreSQL)
DB_USER=postgres
DB_HOST=localhost
DB_DATABASE=dumbake
DB_PASSWORD=your_password
DB_PORT=5432

# Gemini AI API Key (For personalized recommendations)
GEMINI_API_KEY=your_gemini_key

# Stripe Payment Gateways
STRIPE_SECRET_KEY=your_stripe_secret

# Razorpay Gateways
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Twilio SMS Config
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SMTP Email Config
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Dumbake Support" <support@dumbake.com>
