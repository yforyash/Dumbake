{
  "cleanUrls": true,
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/_/backend/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!api|assets|favicon.ico|_next).*)",
      "destination": "/index.html"
    }
  ]
}
