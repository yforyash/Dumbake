{
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/_/backend/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!api|assets|pwa-icon.png|bakery_video.mp4|manifest.json|sw.js).*)",
      "destination": "/index.html"
    }
  ]
}
