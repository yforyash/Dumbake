{
  "name": "dumbake-workspace",
  "version": "1.0.0",
  "description": "Dumbake Bakery Full-stack Workspace",
  "scripts": {
    "install-all": "npm install --prefix backend && npm install --prefix frontend",
    "build": "npm run install-all && npm run build --prefix frontend",
    "backend": "npm run dev --prefix backend",
    "frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "lodash": "^4.18.1",
    "nodemailer": "^8.0.11",
    "pg": "^8.11.5",
    "razorpay": "^2.9.6",
    "serverless-http": "^4.0.0",
    "stripe": "^22.2.1",
    "swagger-jsdoc": "*",
    "swagger-ui-express": "*",
    "twilio": "*",
    "zod": "*"
  }
}
